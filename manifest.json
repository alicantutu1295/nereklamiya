{
  "manifest_version": 3,
  "name": "NeReklamiYa",
  "short_name": "NeReklamiYa",
  "description": "Hızlı ve gizlilik odaklı reklam engelleyici. Reklamları, takipçileri ve analiz araçlarını engeller.",
  "version": "1.0.0",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "NeReklamiYa",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "SiMGEM.png",
      "32": "SiMGEM.png",
      "48": "SiMGEM.png",
      "128": "SiMGEM.png"
    }
  },
  "icons": {
    "16": "SiMGEM.png",
    "32": "SiMGEM.png",
    "48": "SiMGEM.png",
    "128": "SiMGEM.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/page-guard.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/generated-cosmetic-rules.js", "src/content.js"],
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "core_rules",
        "enabled": true,
        "path": "rules/core-rules.json"
      }
    ]
  }
}
